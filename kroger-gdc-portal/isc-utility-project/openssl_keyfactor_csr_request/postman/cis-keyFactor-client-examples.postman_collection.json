{
	"info": {
		"_postman_id": "bb9ab449-245c-4486-b518-79a1dc2101c1",
		"name": "cis-keyFactor-client-examples",
		"description": "Name: cis-keyfactor-client-examples\n\nDESCRIPTION: Postman examples on utilizing the KeyFactor API for client-based requests.\n\nExample requests are broken out in two sections:\n\n1.  csr_enrollment - API calls that are useful for Certificate Signing Requests (CSR)\n2.  reporting - API calls used for reporting expiration, including certificates for monitoring, etc.\n    \n\nPredefined Information\n\nAuthorization - You must change the authorization information in the Postman configuration to use an Active Directory account that use proper access to the KeyFactor environment (i.e. your personal EUID. Ensure that your are including the domain name prefix of \"KROGER\\\\\" to the username.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "csr_enrollment",
			"item": [
				{
					"name": "1_ParseCSR",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									""
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Should return OK\", function() {\r",
									"    pm.response.to.have.status(200)\r",
									"})\r",
									"\r",
									"var jsonData = pm.response.json();\r",
									"var commonName = jsonData[2].split('=');\r",
									"pm.collectionVariables.set(\"cn\",commonName[1]);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "x-keyfactor-requested-with",
								"value": "APIClient",
								"type": "text"
							},
							{
								"key": "x-keyfactor-api-version",
								"value": "1",
								"type": "text",
								"disabled": true
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\r\n    \"csr\": \"{{csr}}\"\r\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "https://{{base_url}}/KeyfactorAPI/Enrollment/CSR/Parse",
							"protocol": "https",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"KeyfactorAPI",
								"Enrollment",
								"CSR",
								"Parse"
							]
						}
					},
					"response": []
				},
				{
					"name": "2_EnrollCSR",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Should return OK\", function() {\r",
									"    pm.response.to.have.status(200)\r",
									"})\r",
									"\r",
									"var jsonData = pm.response.json();\r",
									"pm.collectionVariables.set(\"certificate\", jsonData[\"CertificateInformation\"].Certificates[0]);\r",
									"pm.collectionVariables.set(\"KeyfactorID\", jsonData[\"CertificateInformation\"].KeyfactorID);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "X-Keyfactor-Requested-With",
								"value": "APIClient",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\r\n  \"CSR\": \"{{csr}}\", //Certificate Signing Request from Postman varible\r\n  \"CertificateAuthority\": \"N060CISPKI12.kroger.com\\\\Kroger CA P2\",\r\n  \"IncludeChain\": false,\r\n  \"Timestamp\": \"{{$isoTimestamp}}\",\r\n  \"Template\": \"KrogerWebServer(2048bit)1yr\",\r\n  // NOTE: You can add SAN Values if you CSR does not include them\r\n  // \r\n  // \"SANs\": {\r\n    // SAN DNS EXAMPLE\r\n    //      \"DNS\": [\r\n    // \"hostname1.kroger.com\",\r\n    // \"hostname2.kroger.com\",\r\n    //      ]\r\n  //  },\r\n  \"Metadata\": {\r\n      \"Group\": \"{{group_name}}\",\r\n      \"Environment\": \"Production\"\r\n  }\r\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "https://{{base_url}}/KeyfactorAPI/Enrollment/CSR",
							"protocol": "https",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"KeyfactorAPI",
								"Enrollment",
								"CSR"
							]
						}
					},
					"response": []
				},
				{
					"name": "3_Download",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "X-Keyfactor-Requested-With",
								"value": "APIClient",
								"type": "text"
							},
							{
								"key": "X-CertificateFormat",
								"value": "DER",
								"type": "text"
							},
							{
								"key": "",
								"value": "",
								"type": "text",
								"disabled": true
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\r\n\"CertID\":30971,\r\n\"IncludeChain\":false\r\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "https://{{base_url}}/KeyfactorAPI/Certificates/Download?collectionId={{collectionID}}",
							"protocol": "https",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"",
								"KeyfactorAPI",
								"Certificates",
								"Download"
							],
							"query": [
								{
									"key": "collectionId",
									"value": "{{collectionID}}",
									"description": "The Collection ID assigned to your group's collection."
								}
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "reporting",
			"item": [
				{
					"name": "Expiring Report Example",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "x-keyfactor-requested-with",
								"value": "APIClient",
								"type": "text"
							},
							{
								"key": "",
								"value": "",
								"type": "text",
								"disabled": true
							}
						],
						"url": {
							"raw": "https://{{base_url}}/KeyfactorAPI/Certificates?pq.queryString=(ExpirationDate -ge \"2022-01-15 11:36:20\" AND ExpirationDate -le \"2022-03-01 11:36:20\")&includeMetadata=true&collectionId={{collectionID}}",
							"protocol": "https",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"KeyfactorAPI",
								"Certificates"
							],
							"query": [
								{
									"key": "pq.queryString",
									"value": "(ExpirationDate -ge \"2022-01-15 11:36:20\" AND ExpirationDate -le \"2022-03-01 11:36:20\")",
									"description": "QueryString with begin and end timestamps"
								},
								{
									"key": "includeMetadata",
									"value": "true",
									"description": "Include metadata (i.e. Group and Environment)"
								},
								{
									"key": "collectionId",
									"value": "{{collectionID}}",
									"description": "Your group's collection ID"
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "Ignore Certificate",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "x-keyfactor-requested-with",
								"value": "APIClient",
								"type": "text"
							},
							{
								"key": "",
								"value": "",
								"type": "text",
								"disabled": true
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\r\n  \"Id\": 30098,\r\n  \"Metadata\": {\r\n      \"Group\": \"Ignore\"\r\n  }\r\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "https://{{base_url}}/KeyfactorAPI/Certificates/Metadata?collectionid=0",
							"protocol": "https",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"KeyfactorAPI",
								"Certificates",
								"Metadata"
							],
							"query": [
								{
									"key": "collectionid",
									"value": "0"
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "ImportCertificate",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									""
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "x-keyfactor-requested-with",
								"value": "APIClient",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\r\n    \"Certificate\": \"{{certificate}}\",\r\n    \"Metadata\": { \r\n        \"Group\": \"Unknown\",\r\n        \"Environment\": \"Production\"\r\n     }\r\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "https://{{base_url}}/KeyfactorAPI/Certificates/Import",
							"protocol": "https",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"KeyfactorAPI",
								"Certificates",
								"Import"
							]
						}
					},
					"response": []
				}
			]
		}
	],
