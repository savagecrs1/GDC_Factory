apiVersion: metallb.io/v1beta1
kind: IPAddressPool
metadata:
  name: {{ item.name }}-pool
  namespace: kube-system
spec:
  addresses:
  - {{ item.vip_pool }}
  autoAssign: false
---
apiVersion: metallb.io/v1beta1
kind: L2Advertisement
metadata:
  name: l2advertise-{{ item.name }}
  namespace: kube-system
spec:
  ipAddressPools:
  - {{ item.name }}-pool
  interfaces:
  - gdcenet0.{{ item.vlan_id }}
