#!/usr/bin/env bash
# Automatically generated by Ansible for GEM on GCP Emulation
# This script recreates the primary and secondary VXLAN overlay interfaces on boot.

# Fail on any error
set -e

# ==============================================================================
# PRIMARY VXLAN OVERLAY (vxlan0)
# ==============================================================================
# Ensure clean state
ip link delete vxlan0 2>/dev/null || true

# Create the vxlan0 interface.
# We set MTU to 1410 because GCP VPC underlays enforce a hard 1460 MTU limit.
# A VXLAN header adds 50 bytes of overhead (1460 - 50 = 1410), so our overlay
# must have an MTU of exactly 1410 to prevent dropped packets.
ip link add vxlan0 type vxlan id {{ vxlan_id }} dev ens4 dstport 4789
ip link set dev vxlan0 mtu 1410

# Append FDB entries for the other nodes in the cluster so the overlay can
# discover MAC addresses over the GCP underlay IP network.
{% for node in groups['gdc_nodes'] %}
{% if node != inventory_hostname %}
bridge fdb append to 00:00:00:00:00:00 dst {{ hostvars[node].internal_ip }} dev vxlan0
{% endif %}
{% endfor %}

# Assign IP address and bring the interface up
ip addr add {{ vxlan_ip }}/24 dev vxlan0
ip link set up dev vxlan0

# ==============================================================================
# SECONDARY VXLAN OVERLAYS (gdcenet0.X) - Island Mode Emulation
# ==============================================================================
{% if secondary_networks is defined %}
{% for net in secondary_networks %}
# Network: {{ net.vlan_id }}
ip link delete gdcenet0.{{ net.vlan_id }} 2>/dev/null || true

# Create the secondary interface. MTU 1410 is used here for the same GCP overhead reasons.
ip link add gdcenet0.{{ net.vlan_id }} type vxlan id {{ net.vlan_id }} dev ens4 dstport 4789
ip link set dev gdcenet0.{{ net.vlan_id }} mtu 1410

# Append FDB entries for secondary VXLANs across all nodes
{% for node in groups['gdc_nodes'] %}
{% if node != inventory_hostname %}
bridge fdb append to 00:00:00:00:00:00 dst {{ hostvars[node].internal_ip }} dev gdcenet0.{{ net.vlan_id }}
{% endif %}
{% endfor %}

# Calculate the base IP from the subnet (e.g. 172.16.10.0/24 -> 172.16.10)
SUBNET_BASE="$(echo '{{ net.subnet }}' | cut -d. -f1-3)"

# Determine the host octet based on the hostname. Edge router gets 254. Workstation gets 100.
if [[ "{{ inventory_hostname }}" == "gem_admin_ws" ]]; then
  HOST_OCTET="100"
elif [[ "{{ inventory_hostname }}" == "edge_router_host" ]]; then
  HOST_OCTET="254"
else
  # Extract node number from 'node1', 'node2', etc and add 1 (so node1 gets .2)
  NODE_NUM=$(echo "{{ inventory_hostname }}" | grep -oE '[0-9]+$')
  HOST_OCTET=$((NODE_NUM + 1))
fi

IP_CIDR="${SUBNET_BASE}.${HOST_OCTET}/24"

# Assign IP address and bring the interface up
ip addr add ${IP_CIDR} dev gdcenet0.{{ net.vlan_id }} || true
ip link set up dev gdcenet0.{{ net.vlan_id }}
{% endfor %}
{% endif %}

# ==============================================================================
# MTU CLAMPING (TCP MSS)
# ==============================================================================
# Strictly require TCP MSS clamping on vxlan0 to automatically resize
# large TCP payloads (like etcd mTLS handshakes and Raft snapshots) to match the
# 1410 MTU. Without this, connections experience persistent i/o timeouts and
# context deadline exceeded errors that break cluster quorum.
iptables -t mangle -A POSTROUTING -p tcp --tcp-flags SYN,RST SYN -o vxlan0 -j TCPMSS --clamp-mss-to-pmtu || true
